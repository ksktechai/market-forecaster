# ---- Finnhub (price candles are premium-only; news works on the free tier) ----
# Get a free key at https://finnhub.io. NOTE: the free tier 403s on /stock/candle,
# so prices come from the keyless Yahoo (yfinance) source by default. Finnhub is
# still used for news.
FINNHUB_API_KEY=

# ---- Ollama (qwen3 narrative) ----
# Ollama runs on the host Mac, outside the container -> use host.docker.internal.
OLLAMA_BASE_URL=http://192.168.1.4:11434
OLLAMA_MODEL=qwen3:8b

# ---- Forecast ----
# Canonical symbols (comma-separated). Known:
#   NASDAQ (^IXIC), NZX50 (^NZ50), ASX (S&P/ASX 200), EUROPE (EURO STOXX 50),
#   SINGAPORE (STI), KOREA (KOSPI), INDIA (Nifty 50), UK (FTSE 100)
# NOTE: each symbol runs TimesFM twice (forecast + backtest), so more symbols =
# slower runs. List only what you want delivered.
SYMBOLS=NASDAQ,NZX50,ASX,EUROPE,SINGAPORE,KOREA,INDIA,UK
FORECAST_HORIZON=5
LOOKBACK_DAYS=365
ENABLE_BACKTEST=true

# Optional JSON to override per-source tickers, e.g. use the ENZL ETF for NZX50:
# SYMBOL_MAP_JSON={"NZX50":{"yahoo":"ENZL","proxy":true}}
SYMBOL_MAP_JSON=

# ---- Data source behaviour ----
# Yahoo (yfinance) is the working keyless price source -- leave on.
ENABLE_YAHOO_SOURCE=true
# Only turn on if you have a PREMIUM Finnhub plan (free keys 403 on candles).
# When on, Finnhub is tried first and Yahoo is the fallback.
ENABLE_FINNHUB_CANDLES=false

# ---- Scheduler / delivery ----
# When ENABLE_SCHEDULER=true, one cron job per market fires a few minutes after
# that market's local close (in the market's OWN timezone, so DST is automatic),
# forecasts that market's symbols, and POSTs to HERMES_WEBHOOK_URL. Only markets
# that have a symbol in SYMBOLS get a job.
ENABLE_SCHEDULER=false
HERMES_WEBHOOK_URL=
#
# Per-market overrides (all optional -- sensible local-close defaults are built in).
# Cron is in the market's local time; {MARKET}_TZ sets that timezone.
#   US -> 16:05 America/New_York      NZ -> 17:10 Pacific/Auckland
#   AU -> 16:15 Australia/Sydney      EU -> 17:40 Europe/Berlin
#   SG -> 17:10 Asia/Singapore        KR -> 15:40 Asia/Seoul
#   IN -> 15:40 Asia/Kolkata          UK -> 16:40 Europe/London
# Examples:
# US_CLOSE_CRON=5 16 * * 1-5
# US_TZ=America/New_York
# UK_CLOSE_CRON=40 16 * * 1-5
# UK_TZ=Europe/London

# ---- HTTP ----
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# ---- Logging ----
LOG_LEVEL=INFO

# ---- Model cache ----
# Where Hugging Face caches TimesFM weights. This /models/hf path is the IN-CONTAINER
# path (mounted as a volume in compose so weights persist across restarts).
# Running locally (not Docker)? This path is read-only on macOS -- the app detects
# that and falls back to ~/.cache/huggingface automatically, or set a local path here.
HF_HOME=/models/hf
